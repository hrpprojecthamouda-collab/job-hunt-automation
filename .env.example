# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Register a free app at https://francetravail.io/inscription, subscribe it to
# the "Offres d'emploi v2" API, and paste the credentials it gives you here.

FRANCE_TRAVAIL_CLIENT_ID=your_client_id_here
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret_here

